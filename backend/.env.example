PORT=4000
# Neon: Connect → copy URI, then prefer verify-full (avoids pg driver SSL warning):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=verify-full
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modex_booking
# No trailing slash (or any — we normalize to URL origin in config)
FRONTEND_ORIGIN=https://modex-kjpa.vercel.app/
